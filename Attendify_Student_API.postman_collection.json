{
    "info": {
        "_postman_id": "attendify-student-api",
        "name": "Attendify - Student API",
        "description": "واجهة برمجة التطبيقات (API) الخاصة بتطبيق الطالب في نظام Attendify.\n\nالمصادقة: يستخدم Laravel Sanctum (Bearer Token).\n- أولاً: استدعِ POST /api/student/login للحصول على token.\n- ثم: استخدم الـ token في جميع الطلبات الأخرى.\n\nالردود: جميع الردود بصيغة JSON موحدة:\n```json\n{\n  \"success\": true/false,\n  \"message\": \"...\",\n  \"data\": { ... }\n}\n```",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000/api/student",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "🔐 Authentication",
            "description": "المصادقة وتسجيل الدخول/الخروج",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success && jsonData.data.token) {",
                                    "    pm.collectionVariables.set('token', jsonData.data.token);",
                                    "    console.log('Token saved: ' + jsonData.data.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"student1@example.com\",\n    \"password\": \"password\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "login"
                            ]
                        },
                        "description": "تسجيل الدخول كطالب للحصول على Bearer Token.\nيُحفظ الـ Token تلقائياً في المجموعة.\n\nالحقول المطلوبة:\n- email (string, required)\n- password (string, required)"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "logout"
                            ]
                        },
                        "description": "تسجيل الخروج وإلغاء الـ Token الحالي."
                    }
                },
                {
                    "name": "Get Profile (Me)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "me"
                            ]
                        },
                        "description": "جلب بيانات الملف الشخصي للطالب المسجّل.\n\nيُعيد: id, name, email, role, status, university, college, major, level."
                    }
                }
            ]
        },
