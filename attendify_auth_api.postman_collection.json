{
    "info": {
        "_postman_id": "attendify-auth-api-collection",
        "name": "Attendify - Authentication & Registration",
        "description": "Authentication and registration collection for Attendify.\n\nFrontend login flow:\n1. Call the correct workspace login endpoint.\n2. Read the raw API payload from `data.token` and `data.user`. In Flutter/Dio this is typically `response.data.data.token` and `response.data.data.user`.\n3. Save the token in secure storage, not memory only.\n4. Send `Authorization: Bearer <token>` on every protected request.\n5. Call the matching `/me` endpoint immediately after login to refresh the profile and workspace flags.\n6. If push notifications are enabled, call the workspace `POST /devices/token` endpoint after login.\n7. On app start, validate the saved token with `/me`.\n8. On logout, call `DELETE /devices/token` first if an FCM token was registered, then call `/logout`, then clear local storage.\n\nRegistration helper endpoints return wrapped payloads, so frontend clients should read list data from `response.data.data`.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Public Access",
            "item": [
                {
                    "name": "1.1 Public Data for Registration",
                    "item": [
                        {
                            "name": "Get Universities",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json"
                                    }
                                ],
                                "url": {
                                    "raw": "{{base_url}}/api/public/universities",
                                    "host": [
                                        "{{base_url}}"
                                    ],
                                    "path": [
                                        "api",
                                        "public",
                                        "universities"
                                    ]
                                },
                                "description": "Get all universities. Response payload is wrapped as response.data."
                            },
                            "response": []
                        },
                        {
                            "name": "Get Colleges",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json"
                                    }
                                ],
                                "url": {
                                    "raw": "{{base_url}}/api/public/colleges/:university_id",
                                    "host": [
                                        "{{base_url}}"
                                    ],
                                    "path": [
                                        "api",
                                        "public",
                                        "colleges",
                                        ":university_id"
                                    ],
                                    "variable": [
                                        {
                                            "key": "university_id",
                                            "value": "1"
                                        }
                                    ]
                                },
                                "description": "Get colleges for a university. Supported forms: /api/public/colleges/{university_id} or /api/public/colleges?university_id=1. Response payload is wrapped as response.data."
                            },
                            "response": []
                        },
                        {
                            "name": "Get Majors",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json"
                                    }
                                ],
                                "url": {
                                    "raw": "{{base_url}}/api/public/majors/:college_id",
                                    "host": [
                                        "{{base_url}}"
                                    ],
                                    "path": [
                                        "api",
                                        "public",
                                        "majors",
                                        ":college_id"
                                    ],
                                    "variable": [
                                        {
                                            "key": "college_id",
                                            "value": "1"
                                        }
                                    ]
                                },
                                "description": "Get majors for a college. Supported forms: /api/public/majors/{college_id} or /api/public/majors?college_id=1. Response payload is wrapped as response.data."
                            },
                            "response": []
                        },
                        {
                            "name": "Get Levels",
                            "request": {
                                "method": "GET",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json"
                                    }
                                ],
                                "url": {
                                    "raw": "{{base_url}}/api/public/levels/:major_id",
                                    "host": [
                                        "{{base_url}}"
                                    ],
                                    "path": [
                                        "api",
                                        "public",
                                        "levels",
                                        ":major_id"
                                    ],
                                    "variable": [
                                        {
                                            "key": "major_id",
                                            "value": "1"
                                        }
                                    ]
                                },
                                "description": "Get levels for a major. Supported forms: /api/public/levels/{major_id} or /api/public/levels?major_id=1. Response payload is wrapped as response.data."
                            },
                            "response": []
                        }
                    ]
                },
                {
                    "name": "Register New Account",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Full Name\",\n    \"email\": \"delegate@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"delegate\",\n    \"gender\": \"female\",\n    \"university_id\": 1,\n    \"college_id\": 1,\n    \"major_id\": 1,\n    \"level_id\": 1,\n    \"student_number\": \"20260001\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "register"
                            ]
                        },
                        "description": "Register a new account. student and delegate require university_id, college_id, major_id, level_id, student_number, and gender. doctor requires university_id and college_id only. administrative accounts are not registered directly."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Admin & Administrative Auth",
            "item": [
                {
                    "name": "Login (General or College Admin)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success && jsonData.data.token) {",
                                    "    pm.environment.set(\"admin_token\", jsonData.data.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@attendify.com\",\n    \"password\": \"password\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/admin/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "login"
                            ]
                        },
                        "description": "Authenticate a super admin account through `/api/admin/login`.\n\nRequest body:\n- `email`\n- `password`\n\nFrontend flow:\n1. Read `response.data.data.token` and `response.data.data.user`.\n2. Save the token in secure storage.\n3. Call the admin `/me` endpoint.\n4. Register the Firebase token through the admin `POST /devices/token` endpoint in the Admin collection."
                    },
                    "response": []
                },
                {
                    "name": "Profile (Me)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{admin_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "me"
                            ]
                        },
                        "description": "Use this request on app start and immediately after login to verify the saved admin token and refresh the current profile."
                    },
                    "response": []
                },
                {
                    "name": "Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{admin_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/admin/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "logout"
                            ]
                        },
                        "description": "If push is enabled, remove the device token first through the admin `DELETE /devices/token` endpoint, then call logout and clear local storage."
                    },
                    "response": []
                }
            ],
            "description": "This section documents super admin authentication. For college administrative workspace authentication, use the dedicated Administrative collection and `/api/administrative/login`."
        },
        {
            "name": "3. Student Auth",
            "item": [
                {
                    "name": "Student Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success && jsonData.data.token) {",
                                    "    pm.environment.set(\"student_token\", jsonData.data.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"student@example.com\",\n    \"password\": \"password\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/student/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "student",
                                "login"
                            ]
                        },
                        "description": "Authenticate a student account.\n\nRequest body:\n- `login`: email or student_number\n- `password`\n\nFrontend flow:\n1. Read `response.data.data.token` and `response.data.data.user`.\n2. Save the token in secure storage.\n3. Call `GET /api/student/me`.\n4. Register the Firebase token through `POST /api/student/devices/token` if push is enabled."
                    },
                    "response": []
                },
                {
                    "name": "Student Profile (Me)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{student_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/student/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "student",
                                "me"
                            ]
                        },
                        "description": "Use this request immediately after login and on app start to verify the saved student token and hydrate the current profile."
                    },
                    "response": []
                },
                {
                    "name": "Student Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{student_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/student/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "student",
                                "logout"
                            ]
                        },
                        "description": "If push is enabled, remove the device token through `DELETE /api/student/devices/token` before logout, then clear local storage."
                    },
                    "response": []
                }
            ],
            "description": "Student login uses `login` plus `password`. `login` accepts either the email or the student number."
        },
