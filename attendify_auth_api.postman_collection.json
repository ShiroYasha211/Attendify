        },
        {
            "name": "5. Doctor Auth",
            "item": [
                {
                    "name": "Doctor Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.success && jsonData.data.token) {",
                                    "    pm.environment.set(\"doctor_token\", jsonData.data.token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"doctor@example.com\",\n    \"password\": \"password\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/doctor/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "doctor",
                                "login"
                            ]
                        },
                        "description": "Authenticate a doctor account.\n\nRequest body:\n- `email`\n- `password`\n\nFrontend flow:\n1. Read `response.data.data.token` and `response.data.data.user`.\n2. Save the token in secure storage.\n3. Call `GET /api/doctor/me`.\n4. If `available_workspaces` contains both doctor and administrative, keep the same token and switch only the workspace path.\n5. Register the Firebase token through `POST /api/doctor/devices/token` if push is enabled."
                    },
                    "response": []
                },
                {
                    "name": "Doctor Profile (Me)",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{doctor_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/doctor/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "doctor",
                                "me"
                            ]
                        },
                        "description": "Use this request immediately after login and on app start to verify the saved doctor token and inspect `administrative_access` plus `available_workspaces`."
                    },
                    "response": []
                },
                {
                    "name": "Doctor Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{doctor_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "header": [
