                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/doctor/logout",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "doctor",
                                "logout"
                            ]
                        },
                        "description": "If push is enabled, remove the device token through `DELETE /api/doctor/devices/token` before logout, then clear local storage."
                    },
                    "response": []
                }
            ],
            "description": "Doctor login uses `email` plus `password`. Some doctor accounts also expose `administrative_access=true` and multiple available workspaces."
        }
